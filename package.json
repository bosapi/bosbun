{
  "name": "bosbun-monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "publish": "npm publish --workspace packages/bosbun --access public",
    "publish:dry": "npm publish --workspace packages/bosbun --dry-run",
    "publish:force": "npm publish --workspace packages/bosbun --force"
  }
}
